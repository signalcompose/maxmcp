{
  "name": "MaxMCP",
  "version": "1.2.0",
  "displayname": "MaxMCP",
  "author": "Signal compose",
  "description": "MCP Server for Max/MSP - control Max patches with Claude Code using natural language. Requires the bundled Node.js bridge (support/bridge) and a Claude Code client.",
  "website": "https://github.com/signalcompose/MaxMCP",
  "tags": ["MCP", "AI", "automation", "Claude", "code-generation", "protocol"],
  "max_version_min": "9.0.0",
  "max_version_max": "none",
  "os": {
    "macintosh": {
      "min_version": "13.0",
      "platform": ["aarch64"]
    }
  },
  "package_extra": {
    "reverse_domain": "com.signalcompose",
    "copyright": "Copyright (c) 2026 Signal compose Inc.",
    "license": "Signal compose Fair Trade License v1.0 (see LICENSE)"
  },
  "toolbar_icon": "misc/MaxMCP_toolbar.svg",
  "homepatcher": "00-index.maxpat",
  "externals": {
    "maxmcp": {
      "description": "MaxMCP unified object - MCP server and patch registration for Claude Code control",
      "platforms": ["mac"]
    }
  },
  "filelist": {
    "externals": [
      "maxmcp.mxo"
    ],
    "support": [
      "maxmcp-bridge"
    ],
    "help": [
      "maxmcp.maxhelp"
    ],
    "examples": [
      "00-index.maxpat",
      "01-basic-registration.maxpat",
      "01-claude-code-connection.maxpat",
      "02-custom-alias.maxpat",
      "03-group-assignment.maxpat",
      "04-multi-patch-synth1.maxpat",
      "05-multi-patch-synth2.maxpat",
      "06-multi-patch-fx1.maxpat",
      "07-mcp-tools-test.maxpat"
    ]
  }
}
